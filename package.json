{
  "name": "proorca",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Edge-native homeschool LMS",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "pnpm build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply proorca-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply proorca-db --remote",
    "db:studio": "drizzle-kit studio"
  },
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.5.6",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-router": "^1.168.10",
    "@tanstack/react-start": "^1.167.16",
    "@tanstack/react-table": "^8.21.3",
    "better-auth": "^1.5.6",
    "drizzle-orm": "^0.45.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.31.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "wrangler": "^4.80.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd",
      "sharp"
    ]
  }
}